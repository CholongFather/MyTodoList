            Surface = "#FFFFFF",
            DrawerBackground = "#1E1B4B",
            DrawerText = "#E0E7FF",
            DrawerIcon = "#A5B4FC",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#1E293B",
            TextPrimary = "#1E293B",
            TextSecondary = "#64748B",
