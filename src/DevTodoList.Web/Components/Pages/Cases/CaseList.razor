@page "/cases"

@inject CaseApiClient CaseApi
@inject ProjectApiClient ProjectApi
@inject EnvironmentApiClient EnvApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>케이스 트래커</PageTitle>

<div class="dtl-page-header">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Primary" />
        <MudText Typo="Typo.h5">케이스 트래커</MudText>
    </MudStack>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
        새 케이스
    </MudButton>
</div>

@* 통계 칩 *@
<MudStack Row Spacing="2" Class="mb-3" Style="flex-wrap:wrap;">
    <MudChip T="string" Size="Size.Small" Color="@(_filterStatus is null ? Color.Primary : Color.Default)"
             Variant="@(_filterStatus is null ? Variant.Filled : Variant.Outlined)"
             OnClick="() => SetStatusFilter(null)">전체 @_cases.Count</MudChip>
    <MudChip T="string" Size="Size.Small" Color="@(_filterStatus == CaseStatus.Open ? Color.Error : Color.Default)"
             Variant="@(_filterStatus == CaseStatus.Open ? Variant.Filled : Variant.Outlined)"
             OnClick="() => SetStatusFilter(CaseStatus.Open)">열림 @CountByStatus(CaseStatus.Open)</MudChip>
    <MudChip T="string" Size="Size.Small" Color="@(_filterStatus == CaseStatus.InProgress ? Color.Warning : Color.Default)"
             Variant="@(_filterStatus == CaseStatus.InProgress ? Variant.Filled : Variant.Outlined)"
             OnClick="() => SetStatusFilter(CaseStatus.InProgress)">진행중 @CountByStatus(CaseStatus.InProgress)</MudChip>
    <MudChip T="string" Size="Size.Small" Color="@(_filterStatus == CaseStatus.Resolved ? Color.Success : Color.Default)"
             Variant="@(_filterStatus == CaseStatus.Resolved ? Variant.Filled : Variant.Outlined)"
             OnClick="() => SetStatusFilter(CaseStatus.Resolved)">해결 @CountByStatus(CaseStatus.Resolved)</MudChip>
    <MudChip T="string" Size="Size.Small" Color="@(_filterStatus == CaseStatus.Closed ? Color.Default : Color.Default)"
             Variant="@(_filterStatus == CaseStatus.Closed ? Variant.Filled : Variant.Outlined)"
             OnClick="() => SetStatusFilter(CaseStatus.Closed)">종료 @CountByStatus(CaseStatus.Closed)</MudChip>
</MudStack>

@* 필터 바 *@
<MudPaper Class="dtl-filter-bar mb-4" Elevation="0">
    <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Style="flex-wrap:wrap;">
        <MudSelect T="CaseCategory?" @bind-Value="_filterCategory" Label="카테고리" Variant="Variant.Outlined"
                   Margin="Margin.Dense" Clearable Style="min-width:140px;">
            @foreach (CaseCategory cc in Enum.GetValues<CaseCategory>()) { <MudSelectItem T="CaseCategory?" Value="cc">@cc.ToKorean()</MudSelectItem> }
        </MudSelect>
        <MudSelect T="long?" @bind-Value="_filterEnvId" Label="환경" Variant="Variant.Outlined"
                   Margin="Margin.Dense" Clearable Style="min-width:140px;">
            @foreach (var env in _environments)
            {
                <MudSelectItem T="long?" Value="env.Id">@env.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="long?" @bind-Value="_filterProjectId" Label="프로젝트" Variant="Variant.Outlined"
                   Margin="Margin.Dense" Clearable Style="min-width:160px;">
            @foreach (var p in _projects)
            {
                <MudSelectItem T="long?" Value="p.Id">@p.Id : @p.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField T="string" @bind-Value="_search" Label="검색" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                      OnKeyDown="OnSearchKeyDown" Style="min-width:200px;" />
        <MudButton Variant="Variant.Outlined" OnClick="LoadAsync" StartIcon="@Icons.Material.Filled.Refresh">조회</MudButton>
    </MudStack>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate />
}
else if (_filtered.Count == 0)
{
    <MudPaper Class="dtl-section pa-8" Elevation="0" Style="text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Class="mud-text-secondary mb-2" />
        <MudText Typo="Typo.body1" Class="mud-text-secondary">케이스가 없습니다.</MudText>
    </MudPaper>
}
else
{
    <MudPaper Class="dtl-section" Elevation="0">
        <MudSimpleTable Dense Hover Elevation="0">
            <thead>
                <tr>
                    <th style="width:40px;">#</th>
                    <th>제목</th>
                    <th style="width:80px;">상태</th>
                    <th style="width:80px;">우선순위</th>
                    <th style="width:100px;">카테고리</th>
                    <th style="width:80px;">환경</th>
                    <th style="width:100px;">담당자</th>
                    <th style="width:50px;">링크</th>
                    <th style="width:40px;">노트</th>
                    <th style="width:100px;">생성일</th>
                    <th style="width:40px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in _filtered)
                {
                    <tr class="dtl-list-item" @onclick="() => GoToDetail(c.Id)">
                        <td><MudText Typo="Typo.caption">@c.Id</MudText></td>
                        <td>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@c.Title</MudText>
                                @if (c.ProjectName is not null)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@c.ProjectName</MudText>
                                }
                            </MudStack>
                        </td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusColor(c.CaseStatus)" Variant="Variant.Filled">@StatusText(c.CaseStatus)</MudChip></td>
                        <td><MudChip T="string" Size="Size.Small" Color="@PriorityColor(c.Priority)" Variant="Variant.Outlined">@PriorityText(c.Priority)</MudChip></td>
                        <td><MudText Typo="Typo.caption">@CategoryText(c.CaseCategory)</MudText></td>
                        <td>
                            @if (c.EnvironmentName is not null)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                         Style="@(c.EnvironmentColor is not null ? $"color:{c.EnvironmentColor}" : "")">@c.EnvironmentName</MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">-</MudText>
                            }
                        </td>
                        <td><MudText Typo="Typo.caption">@(c.Assignee ?? "-")</MudText></td>
                        <td @onclick:stopPropagation="true">
                            @{ var linkCount = c.Links.Count + (string.IsNullOrEmpty(c.JiraUrl) ? 0 : 1) + (string.IsNullOrEmpty(c.WideUrl) ? 0 : 1); }
                            @if (linkCount > 0)
                            {
                                <MudBadge Content="@linkCount" Color="Color.Info" Overlap>
                                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                                </MudBadge>
                            }
                        </td>
                        <td>
                            @if (c.NoteCount > 0)
                            {
                                <MudBadge Content="@c.NoteCount" Color="Color.Primary" Overlap>
                                    <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Size="Size.Small" />
                                </MudBadge>
                            }
                        </td>
                        <td><MudText Typo="Typo.caption">@c.CreatedAt.ToString("MM/dd HH:mm")</MudText></td>
                        <td @onclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => ConfirmDeleteAsync(c))" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@* 생성 다이얼로그 *@
<MudDialog @bind-Visible="_dialogVisible" Options="new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">새 케이스</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="pa-2">
            <MudTextField @bind-Value="_form.Title" Label="제목" Required RequiredError="제목을 입력하세요"
                          Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_form.Description" Label="설명" Lines="3" Variant="Variant.Outlined" />

            <MudStack Row Spacing="2">
                <MudSelect T="CaseCategory" @bind-Value="_form.CaseCategory" Label="카테고리" Variant="Variant.Outlined" Style="flex:1;">
                    @foreach (CaseCategory cc in Enum.GetValues<CaseCategory>()) { <MudSelectItem T="CaseCategory" Value="cc">@cc.ToKorean()</MudSelectItem> }
                </MudSelect>
                <MudSelect T="long?" @bind-Value="_form.EnvironmentId" Label="환경" Variant="Variant.Outlined" Clearable Style="flex:1;">
                    @foreach (var env in _environments)
                    {
                        <MudSelectItem T="long?" Value="env.Id">@env.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>

            <MudStack Row Spacing="2">
                <MudSelect T="int" @bind-Value="_form.Priority" Label="우선순위" Variant="Variant.Outlined" Style="flex:1;">
                    <MudSelectItem T="int" Value="0">낮음</MudSelectItem>
                    <MudSelectItem T="int" Value="1">보통</MudSelectItem>
                    <MudSelectItem T="int" Value="2">높음</MudSelectItem>
                    <MudSelectItem T="int" Value="3">심각</MudSelectItem>
                </MudSelect>
                <MudSelect T="long?" @bind-Value="_form.ProjectId" Label="프로젝트" Variant="Variant.Outlined" Clearable Style="flex:1;">
                    @foreach (var p in _projects)
                    {
                        <MudSelectItem T="long?" Value="p.Id">@p.Id : @p.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>

            <MudStack Row Spacing="2">
                <MudTextField @bind-Value="_form.Reporter" Label="보고자" Variant="Variant.Outlined" Style="flex:1;" />
                <MudTextField @bind-Value="_form.Assignee" Label="담당자" Variant="Variant.Outlined" Style="flex:1;" />
            </MudStack>

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">취소</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
            저장
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CaseDto> _cases = [];
    private List<CaseDto> _filtered = [];
    private List<ProjectDto> _projects = [];
    private List<EnvironmentDto> _environments = [];
    private bool _loading = true;
    private bool _saving;
    private bool _dialogVisible;
    private CreateCaseRequest _form = new();

    // 필터
    private CaseStatus? _filterStatus;
    private CaseCategory? _filterCategory;
    private long? _filterEnvId;
    private long? _filterProjectId;
    private string? _search;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _projects = await ProjectApi.GetAllAsync();
            _environments = await EnvApi.GetAllAsync();
        }
        catch { /* 로드 실패 시 빈 목록 */}
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _cases = await CaseApi.GetAllAsync(search: _search);
            ApplyLocalFilters();
        }
        catch (Exception ex) { Snackbar.Add($"로드 실패: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private void ApplyLocalFilters()
    {
        var q = _cases.AsEnumerable();
        if (_filterStatus.HasValue) q = q.Where(c => c.CaseStatus == _filterStatus.Value);
        if (_filterCategory.HasValue) q = q.Where(c => c.CaseCategory == _filterCategory.Value);
        if (_filterEnvId.HasValue) q = q.Where(c => c.EnvironmentId == _filterEnvId.Value);
        if (_filterProjectId.HasValue) q = q.Where(c => c.ProjectId == _filterProjectId.Value);
        _filtered = q.ToList();
    }

    private void SetStatusFilter(CaseStatus? status)
    {
        _filterStatus = status;
        ApplyLocalFilters();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadAsync();
    }

    private int CountByStatus(CaseStatus status) => _cases.Count(c => c.CaseStatus == status);

    private void GoToDetail(long id) => Navigation.NavigateTo($"/cases/detail/{id}");

    // === 다이얼로그 ===

    private void OpenCreateDialog()
    {
        _form = new CreateCaseRequest { Priority = 1 };
        _dialogVisible = true;
    }

    private void CloseDialog() => _dialogVisible = false;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Title)) { Snackbar.Add("제목을 입력하세요.", Severity.Warning); return; }
        _saving = true;
        try
        {
            await CaseApi.CreateAsync(_form);
            Snackbar.Add("생성되었습니다.", Severity.Success);
            _dialogVisible = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"저장 실패: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task ConfirmDeleteAsync(CaseDto c)
    {
        var result = await DialogService.ShowMessageBoxAsync("케이스 삭제", $"'{c.Title}' 케이스를 삭제하시겠습니까?", yesText: "삭제", cancelText: "취소");
        if (result == true)
        {
            try
            {
                await CaseApi.DeleteAsync(c.Id);
                Snackbar.Add("삭제되었습니다.", Severity.Success);
                await LoadAsync();
            }
            catch (Exception ex) { Snackbar.Add($"삭제 실패: {ex.Message}", Severity.Error); }
        }
    }

    // === 헬퍼 ===

    private static Color StatusColor(CaseStatus s) => s switch
    {
        CaseStatus.Open => Color.Error,
        CaseStatus.InProgress => Color.Warning,
        CaseStatus.Resolved => Color.Success,
        CaseStatus.Closed => Color.Default,
        _ => Color.Default
    };

    private static string StatusText(CaseStatus s) => s.ToKorean();

    private static Color PriorityColor(int p) => p switch
    {
        3 => Color.Error,
        2 => Color.Warning,
        1 => Color.Info,
        _ => Color.Default
    };

    private static string PriorityText(int p) => p switch
    {
        3 => "심각",
        2 => "높음",
        1 => "보통",
        _ => "낮음"
    };

    private static string CategoryText(CaseCategory c) => c.ToKorean();
}
