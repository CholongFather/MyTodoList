@page "/schedule"

@inject ScheduleApiClient ScheduleApi
@inject ProjectApiClient ProjectApi
@inject TeamApiClient TeamApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject AssigneeTypeApiClient AssigneeTypeApi
@inject IJSRuntime JS

<PageTitle>일정 등록</PageTitle>
<div class="dtl-page-header">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" />
        <MudText Typo="Typo.h5">일정 텍스트 파싱</MudText>
    </MudStack>
</div>

<MudTabs Elevation="0" Rounded ApplyEffectsToContainer Class="dtl-section">
    @* 탭 1: 일정 입력 *@
    <MudTabPanel Text="일정 입력" Icon="@Icons.Material.Filled.Edit">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="0">
                    <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600;">일정 텍스트 입력</MudText>
                    <MudTextField @bind-Value="_text" Lines="16" Variant="Variant.Outlined" Placeholder="@_placeholder" FullWidth />
                    <MudStack Row Spacing="3" AlignItems="AlignItems.Center" Class="mt-3">
                        <SearchableSelect TItem="ProjectDto" TValue="long"
                            Items="_projects" ValueSelector="@(p => p.Id)" TextSelector="@(p => $"{p.Id} : {p.Name}")"
                            @bind-Value="_projectId" Label="프로젝트" Style="flex:1;" />
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ParseAsync" Disabled="@(string.IsNullOrWhiteSpace(_text) || _parsing)" StartIcon="@Icons.Material.Filled.Preview">미리보기</MudButton>
                    </MudStack>
                    @* 팀/작업분류/담당유형 선택 *@
                    <MudStack Row Spacing="3" AlignItems="AlignItems.Center" Class="mt-2">
                        <SearchableSelect TItem="TeamDto" TValue="long?"
                            Items="_teams" ValueSelector="@(t => (long?)t.Id)" TextSelector="@(t => t.Name)"
                            @bind-Value="_defaultTeamId" @bind-Value:after="OnDefaultTeamChanged" Label="기본 담당 팀" Clearable Style="flex:1;" />
                        <SearchableSelect TItem="WorkCategoryDto" TValue="long?"
                            Items="_defaultCategories" ValueSelector="@(cat => (long?)cat.Id)" TextSelector="@(cat => cat.Name)"
                            @bind-Value="_defaultWorkCategoryId" Label="작업 분류" Clearable Style="flex:1;" />
                        <MudSelect T="long?" @bind-Value="_defaultAssigneeTypeId" Label="담당 유형" Variant="Variant.Outlined" Dense Style="min-width:120px;" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var at in _assigneeTypes) { <MudSelectItem T="long?" Value="at.Id">@at.Name</MudSelectItem> }
                        </MudSelect>
                        <MudCheckBox T="bool" Value="_defaultIsExternal" ValueChanged="OnDefaultExternalChanged" Label="외부" Color="Color.Dark" Dense />
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="0">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">파싱 결과 미리보기</MudText>
                        @if (_parsed.Count > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@_parsed.Count 건</MudChip>
                        }
                    </MudStack>

                    @if (_parsing) { <MudProgressLinear Color="Color.Primary" Indeterminate /> }
                    else if (_parsed.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Text">왼쪽에 일정 텍스트를 입력하고 미리보기를 클릭하세요.</MudAlert>
                    }
                    else
                    {
                        <MudSimpleTable Dense Hover Striped Style="border-radius:8px;">
                            <thead>
                                <tr>
                                    <th>제목</th>
                                    <th>시작일</th>
                                    <th>종료일</th>
                                    <th>유형</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _parsed)
                                {
                                    <tr>
                                        <td style="@(item.Depth > 0 ? $"padding-left:{item.Depth * 20 + 8}px;" : "")">
                                            @if (item.Depth > 0) { <span style="color:#999; margin-right:4px;">└</span> }
                                            @item.Title
                                        </td>
                                        <td>@item.StartDate?.ToString("yyyy-MM-dd")</td>
                                        <td>@item.EndDate?.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @if (item.IsMilestone) { <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">마일스톤</MudChip> }
                                            else { <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">기간</MudChip> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>

                        <MudStack Row Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync" Style="flex:1;"
                                       Disabled="@(_projectId == 0 || _creating)" StartIcon="@Icons.Material.Filled.PlaylistAdd">
                                @if (_creating) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                                일괄 생성 (@(_parsed.Count)건)
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ReplaceAsync" Style="flex:1;"
                                       Disabled="@(_projectId == 0 || _replacing)" StartIcon="@Icons.Material.Filled.SwapHoriz">
                                @if (_replacing) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                                일괄 교체 (@(_parsed.Count)건)
                            </MudButton>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* 탭 2: 템플릿 가이드 *@
    <MudTabPanel Text="템플릿 가이드" Icon="@Icons.Material.Filled.Description">
        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600;">일정 작성 가이드</MudText>
        <MudAlert Severity="Severity.Info" Class="mb-4">
            아래 템플릿을 복사하여 "일정 입력" 탭에 붙여넣기 하세요. 날짜와 항목명을 수정하면 자동으로 파싱됩니다.
        </MudAlert>

        <MudGrid Spacing="3">
            @foreach (var tmpl in _templates)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="1" Style="border-radius:12px;">
                        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@tmpl.Icon" Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2" Style="font-weight:700;">@tmpl.Name</MudText>
                            </MudStack>
                            <MudStack Row Spacing="1">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ContentCopy"
                                           OnClick="@(() => CopyToClipboard(tmpl.Content))">복사</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowForward"
                                           OnClick="@(() => UseTemplate(tmpl.Content))">사용</MudButton>
                            </MudStack>
                        </MudStack>
                        <MudText Typo="Typo.caption" Class="mb-2" Style="color:#888;">@tmpl.Description</MudText>
                        <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); border-radius:8px; font-family:monospace; font-size:12px; white-space:pre-wrap; line-height:1.6; max-height:300px; overflow-y:auto;">@tmpl.Content</MudPaper>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudDivider Class="my-4" />
        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600;">작성 규칙</MudText>
        <MudSimpleTable Dense Hover Style="border-radius:8px;">
            <thead>
                <tr><th>패턴</th><th>예시</th><th>설명</th></tr>
            </thead>
            <tbody>
                <tr><td><code>제목: 시작일 ~ 종료일</code></td><td>개발: 2026. 4. 1. ~ 2026. 4. 15.</td><td>기간 작업</td></tr>
                <tr><td><code>제목: ~ 종료일</code></td><td>기획: ~ 2026. 3. 5.</td><td>종료일만 (시작일은 오늘)</td></tr>
                <tr><td><code>제목: 시작일 부터</code></td><td>프로모션 시작: 2026. 4. 29. 부터</td><td>마일스톤 (단일 날짜)</td></tr>
                <tr><td><code>제목: 시작일</code></td><td>배포일: 2026. 4. 28.</td><td>마일스톤</td></tr>
                <tr><td>들여쓰기 (2칸/탭)</td><td>&nbsp;&nbsp;서비스개발팀: 4. 1. ~ 4. 15.</td><td>하위 작업</td></tr>
                <tr><td>날짜 형식</td><td>2026. 4. 1. / 2026-04-01 / 4/1</td><td>다양한 형식 지원</td></tr>
            </tbody>
        </MudSimpleTable>
    </MudTabPanel>

    @* 탭 3: API 가이드 *@
    <MudTabPanel Text="API 가이드" Icon="@Icons.Material.Filled.Api">
        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600;">REST API로 일정 등록하기</MudText>
        <MudAlert Severity="Severity.Info" Class="mb-4">
            외부 도구(Postman, curl, PowerShell 등)에서 직접 API를 호출하여 일정을 등록할 수 있습니다.
        </MudAlert>

        @* API 1: 프로젝트 목록 *@
        <MudPaper Class="pa-4 mb-3" Elevation="1" Style="border-radius:12px;">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">GET</MudChip>
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;">프로젝트 목록 조회</MudText>
                </MudStack>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="@(() => CopyToClipboard(_apiGetProjects))">복사</MudButton>
            </MudStack>
            <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); border-radius:8px; font-family:monospace; font-size:12px; white-space:pre-wrap; color:var(--mud-palette-text-primary); overflow-x:auto;">@_apiGetProjects</MudPaper>
        </MudPaper>

        @* API 2: 프로젝트 생성 *@
        <MudPaper Class="pa-4 mb-3" Elevation="1" Style="border-radius:12px;">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">POST</MudChip>
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;">프로젝트 생성</MudText>
                </MudStack>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="@(() => CopyToClipboard(_apiCreateProject))">복사</MudButton>
            </MudStack>
            <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); border-radius:8px; font-family:monospace; font-size:12px; white-space:pre-wrap; color:var(--mud-palette-text-primary); overflow-x:auto;">@_apiCreateProject</MudPaper>
        </MudPaper>

        @* API 3: 할일 생성 *@
        <MudPaper Class="pa-4 mb-3" Elevation="1" Style="border-radius:12px;">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">POST</MudChip>
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;">할일 직접 생성</MudText>
                </MudStack>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="@(() => CopyToClipboard(_apiCreateTodo))">복사</MudButton>
            </MudStack>
            <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); border-radius:8px; font-family:monospace; font-size:12px; white-space:pre-wrap; color:var(--mud-palette-text-primary); overflow-x:auto;">@_apiCreateTodo</MudPaper>
        </MudPaper>

        @* API 4: 일정 일괄 교체 *@
        <MudPaper Class="pa-4 mb-3" Elevation="1" Style="border-radius:12px;">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">PUT</MudChip>
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;">일정 일괄 교체 (기존 삭제 + 새로 생성)</MudText>
                </MudStack>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="@(() => CopyToClipboard(_apiScheduleReplace))">복사</MudButton>
            </MudStack>
            <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); border-radius:8px; font-family:monospace; font-size:12px; white-space:pre-wrap; color:var(--mud-palette-text-primary); overflow-x:auto;">@_apiScheduleReplace</MudPaper>
        </MudPaper>

        @* API 5: 일정 텍스트 파싱 + 생성 *@
        <MudPaper Class="pa-4 mb-3" Elevation="1" Style="border-radius:12px;">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">POST</MudChip>
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;">일정 텍스트 파싱 후 일괄 생성</MudText>
                </MudStack>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="@(() => CopyToClipboard(_apiScheduleCreate))">복사</MudButton>
            </MudStack>
            <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); border-radius:8px; font-family:monospace; font-size:12px; white-space:pre-wrap; color:var(--mud-palette-text-primary); overflow-x:auto;">@_apiScheduleCreate</MudPaper>
        </MudPaper>

        <MudDivider Class="my-4" />
        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600;">필드 참조</MudText>
        <MudSimpleTable Dense Hover Style="border-radius:8px;">
            <thead><tr><th>필드</th><th>타입</th><th>필수</th><th>설명</th></tr></thead>
            <tbody>
                <tr><td>title</td><td>string</td><td>Y</td><td>할일 제목 (최대 200자)</td></tr>
                <tr><td>description</td><td>string</td><td>N</td><td>상세 설명</td></tr>
                <tr><td>projectId</td><td>long</td><td>Y</td><td>프로젝트 ID</td></tr>
                <tr><td>priority</td><td>int</td><td>N</td><td>0=Low, 1=Normal, 2=High, 3=Urgent</td></tr>
                <tr><td>startDate</td><td>DateTime</td><td>N</td><td>시작일 (yyyy-MM-dd)</td></tr>
                <tr><td>dueDate</td><td>DateTime</td><td>N</td><td>마감일 (yyyy-MM-dd)</td></tr>
                <tr><td>endDate</td><td>DateTime</td><td>N</td><td>종료일 (yyyy-MM-dd)</td></tr>
                <tr><td>status</td><td>int</td><td>N</td><td>0=Todo, 1=InProgress, 2=Done, 3=Archived</td></tr>
            </tbody>
        </MudSimpleTable>
    </MudTabPanel>
</MudTabs>

@code {
    private List<ProjectDto> _projects = [];
    private List<ScheduleParsedItemDto> _parsed = [];
    private long _projectId;
    private string? _text;
    private bool _parsing, _creating, _replacing;

    // 팀/작업분류/담당유형 필드
    private List<TeamDto> _teams = [];
    private long? _defaultTeamId;
    private long? _defaultWorkCategoryId;
    private long? _defaultAssigneeTypeId;
    private List<AssigneeTypeDto> _assigneeTypes = [];
    private bool _defaultIsExternal;
    private List<WorkCategoryDto> _defaultCategories = [];
    private const string _placeholder = @"기획:  ~ 2026. 3. 5.
디자인: ~ 2026. 3. 6.
마크업: ~ 2026. 3. 10.
개발
  게토개발팀: 2026. 3. 9. ~ 2026. 3. 17.
  서비스개발팀: 2026. 3. 9. ~ 2026. 3. 27.
QA
  내부 QA: 2026. 4. 1. ~ 2026. 4. 16.
프로모션 시작: 2026. 4. 23. 부터";

    protected override async Task OnInitializedAsync()
    {
        _projects = await ProjectApi.GetAllAsync();
        if (_projects.Count > 0) _projectId = _projects[0].Id;
        _teams = await TeamApi.GetAllAsync();
        _assigneeTypes = await AssigneeTypeApi.GetAllAsync();
        _defaultAssigneeTypeId = _assigneeTypes.FirstOrDefault(at => at.IsMine)?.Id;
    }

    private async Task ParseAsync()
    {
        if (string.IsNullOrWhiteSpace(_text)) return;
        _parsing = true;
        try { _parsed = await ScheduleApi.ParseAsync(_text); }
        catch (Exception ex) { Snackbar.Add($"파싱 실패: {ex.Message}", Severity.Error); }
        finally { _parsing = false; }
    }

    /// <summary>팀 선택 변경 시 작업분류 목록 갱신</summary>
    private void OnDefaultTeamChanged()
    {
        var team = _teams.FirstOrDefault(t => t.Id == _defaultTeamId);
        _defaultCategories = team?.WorkCategories ?? [];
        if (_defaultCategories.All(c => c.Id != _defaultWorkCategoryId))
            _defaultWorkCategoryId = _defaultCategories.FirstOrDefault()?.Id;
    }

    /// <summary>외부 일정 토글 → 타인 작업 강제</summary>
    private void OnDefaultExternalChanged(bool val)
    {
        _defaultIsExternal = val;
        if (val) _defaultAssigneeTypeId = _assigneeTypes.FirstOrDefault(at => !at.IsMine)?.Id;
    }

    /// <summary>선택된 담당 유형 ID로부터 AssigneeType 열거형 결정</summary>
    private AssigneeType ResolveAssigneeType()
    {
        var at = _assigneeTypes.FirstOrDefault(a => a.Id == _defaultAssigneeTypeId);
        return at is { IsMine: true } ? AssigneeType.Mine : AssigneeType.Others;
    }

    private async Task CreateAsync()
    {
        _creating = true;
        try
        {
            var result = await ScheduleApi.CreateAsync(_text!, _projectId,
                _defaultTeamId, _defaultWorkCategoryId, ResolveAssigneeType(), _defaultAssigneeTypeId, _defaultIsExternal);
            Snackbar.Add($"{result.Count}건의 할일이 생성되었습니다.", Severity.Success);
            Navigation.NavigateTo("/gantt");
        }
        catch (Exception ex) { Snackbar.Add($"생성 실패: {ex.Message}", Severity.Error); }
        finally { _creating = false; }
    }

    private async Task ReplaceAsync()
    {
        var projectName = _projects.FirstOrDefault(p => p.Id == _projectId)?.Name ?? "";
        var confirmed = await Dialog.ShowMessageBoxAsync(
            "일괄 교체 확인",
            $"프로젝트 \"{projectName}\"의 기존 일정을 모두 삭제하고 새로 {_parsed.Count}건을 생성합니다. 이 작업은 되돌릴 수 없습니다.",
            yesText: "교체", cancelText: "취소");
        if (confirmed != true) return;

        _replacing = true;
        try
        {
            var result = await ScheduleApi.ReplaceAsync(_text!, _projectId,
                _defaultTeamId, _defaultWorkCategoryId, ResolveAssigneeType(), _defaultAssigneeTypeId, _defaultIsExternal);
            Snackbar.Add($"기존 {result?.DeletedCount ?? 0}건 삭제, 새로 {result?.CreatedItems.Count ?? 0}건 생성 완료!", Severity.Success);
            Navigation.NavigateTo("/gantt");
        }
        catch (Exception ex) { Snackbar.Add($"교체 실패: {ex.Message}", Severity.Error); }
        finally { _replacing = false; }
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            Snackbar.Add("클립보드에 복사되었습니다.", Severity.Success);
        }
        catch { Snackbar.Add("복사 실패. 수동으로 복사해주세요.", Severity.Warning); }
    }

    private void UseTemplate(string content)
    {
        _text = content;
        _parsed.Clear();
        Snackbar.Add("템플릿이 입력란에 적용되었습니다.", Severity.Info);
    }

    // ===== 템플릿 데이터 =====
    private readonly List<ScheduleTemplate> _templates =
    [
        new()
        {
            Name = "프로모션 일정 (기본)",
            Description = "기획 → 디자인 → 개발 → QA → 런칭 순서의 표준 프로모션 일정",
            Icon = Icons.Material.Filled.Campaign,
            Content = @"기획: ~ 2026. 4. 5.
디자인: ~ 2026. 4. 10.
마크업: 2026. 4. 7. ~ 2026. 4. 14.
