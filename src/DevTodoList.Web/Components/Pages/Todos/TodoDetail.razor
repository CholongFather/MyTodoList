@page "/todos/detail/{Id:long}"
@implements IDisposable

@using DevTodoList.Shared.Helpers

@inject TodoApiClient TodoApi
@inject ProjectApiClient ProjectApi
@inject TagApiClient TagApi
@inject TeamApiClient TeamApi
@inject WorkerApiClient WorkerApi
@inject LinkTypeApiClient LinkTypeApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>@(_todo?.Title ?? "할일 상세")</PageTitle>

@if (_loading) { <MudProgressLinear Color="Color.Primary" Indeterminate /> }
else if (_todo is null) { <MudAlert Severity="Severity.Error">할일을 찾을 수 없습니다.</MudAlert> }
else
{
    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("/todos"))" />
            <MudText Typo="Typo.h5">할일 상세</MudText>
        </MudStack>
        <MudStack Row Spacing="1">
            @if (_todo!.AssigneeType == AssigneeType.Mine)
            {
                @* 내 작업: 빠른 상태 전환 버튼 *@
                @if (_todo.Status == TodoStatus.Todo)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="@(() => QuickStatusAsync(TodoStatus.InProgress))" Disabled="_saving" StartIcon="@Icons.Material.Filled.PlayArrow">시작</MudButton>
                }
                else if (_todo.Status == TodoStatus.InProgress)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => QuickStatusAsync(TodoStatus.Done))" Disabled="_saving" StartIcon="@Icons.Material.Filled.CheckCircle">완료</MudButton>
                }
                else if (_todo.Status == TodoStatus.Done)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Dark" OnClick="@(() => QuickStatusAsync(TodoStatus.Archived))" Disabled="_saving" StartIcon="@Icons.Material.Filled.Archive">보관</MudButton>
                }
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="DeleteAsync" Disabled="_saving" StartIcon="@Icons.Material.Filled.Delete">삭제</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="DuplicateAsync" Disabled="_saving" StartIcon="@Icons.Material.Filled.ContentCopy">복제</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ManualSaveAsync" Disabled="_saving" StartIcon="@Icons.Material.Filled.Save">저장</MudButton>
        </MudStack>
    </MudStack>

    @* 기본 정보 *@
    <MudPaper Class="pa-4 mb-4 dtl-section" Elevation="0">
        <div class="dtl-section-header">
            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" />
            <MudText Typo="Typo.subtitle1">기본 정보</MudText>
        </div>
        <MudGrid>
            <MudItem xs="12"><MudTextField @bind-Value="_form.Title" @bind-Value:after="ScheduleAutoSave" Label="제목" Required Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_form.Description" @bind-Value:after="ScheduleAutoSave" Label="설명" Lines="4" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="6" sm="3">
                @if (_todo!.AssigneeType == AssigneeType.Others)
                {
                    @* 타인 작업: 날짜 기반 자동 상태 표시 *@
                    var cs = OthersStatusHelper.Compute(_todo.StartDate, _todo.EndDate, _todo.DueDate);
                    <MudField Label="상태 (자동)" Variant="Variant.Outlined">
                        <MudChip T="string" Size="Size.Small" Color="@OthersColor(cs)" Variant="Variant.Filled">@OthersStatusHelper.ToLabel(cs)</MudChip>
                    </MudField>
                }
                else
                {
                    <MudSelect T="TodoStatus" Value="_form.Status" ValueChanged="OnStatusChanged" Label="상태" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                        @foreach (TodoStatus s in Enum.GetValues<TodoStatus>()) { <MudSelectItem T="TodoStatus" Value="s">@SL(s)</MudSelectItem> }
                    </MudSelect>
                }
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudSelect T="TodoPriority" @bind-Value="_form.Priority" @bind-Value:after="AutoSaveAsync" Label="우선순위" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                    @foreach (TodoPriority p in Enum.GetValues<TodoPriority>()) { <MudSelectItem T="TodoPriority" Value="p">@PL(p)</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <SearchableSelect TItem="ProjectDto" TValue="long"
                    Items="_projects" ValueSelector="@(p => p.Id)" TextSelector="@(p => p.Name)"
                    @bind-Value="_form.ProjectId" @bind-Value:after="AutoSaveAsync" Label="프로젝트" />
            </MudItem>
            @* 팀/작업분류/담당유형 *@
            <MudItem xs="12" sm="4">
                <SearchableSelect TItem="TeamDto" TValue="long?"
                    Items="_teams" ValueSelector="@(t => (long?)t.Id)" TextSelector="@(t => t.Name)"
                    @bind-Value="_formTeamId" @bind-Value:after="OnTeamChangedAndSave" Label="담당 팀" Clearable />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="long?" @bind-Value="_formWorkCategoryId" @bind-Value:after="AutoSaveAsync" Label="작업 분류" Variant="Variant.Outlined" Clearable AnchorOrigin="Origin.BottomCenter">
                    @foreach (var cat in _availableCategories) { <MudSelectItem T="long?" Value="cat.Id">@cat.Name</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudCheckBox T="bool" Value="_formIsExternal" ValueChanged="OnExternalChanged" Label="외부 일정" Color="Color.Dark" Dense />
            </MudItem>
            @if (_formIsExternal)
            {
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_formExternalLabel" @bind-Value:after="ScheduleAutoSave" Label="외부 채널명" Variant="Variant.Outlined" Placeholder="예: NK 이벤트빌더, 바람의나라 QA" />
                </MudItem>
            }
            <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_startDate" @bind-Date:after="AutoSaveAsync" Label="시작일" Variant="Variant.Outlined" Clearable DateFormat="yyyy-MM-dd" /></MudItem>
            <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_endDate" @bind-Date:after="AutoSaveAsync" Label="마감일" Variant="Variant.Outlined" Clearable DateFormat="yyyy-MM-dd" /></MudItem>
            @* 계획일 *@
            <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_plannedStartDate" @bind-Date:after="AutoSaveAsync" Label="계획 시작일" Variant="Variant.Outlined" Clearable DateFormat="yyyy-MM-dd" /></MudItem>
            <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_plannedEndDate" @bind-Date:after="AutoSaveAsync" Label="계획 마감일" Variant="Variant.Outlined" Clearable DateFormat="yyyy-MM-dd" /></MudItem>
            @* 실제 일정 표시 *@
            @if (_todo?.ActualStartDate.HasValue == true || _todo?.IsDelayed == true)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense Variant="Variant.Text" Class="mt-0">
                        @if (_todo.ActualStartDate.HasValue)
                        {
                            <span><b>실제:</b> @_todo.ActualStartDate?.ToString("yyyy-MM-dd") ~ @(_todo.ActualEndDate?.ToString("yyyy-MM-dd") ?? "진행중")</span>
                        }
                        @if (_todo.IsDelayed)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Class="ml-2">@(_todo.DelayDays)일 지연</MudChip>
                        }
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

    @* 태그 *@
    <MudPaper Class="pa-4 mb-4 dtl-section" Elevation="0">
        <div class="dtl-section-header">
            <MudIcon Icon="@Icons.Material.Filled.Label" Color="Color.Secondary" />
            <MudText Typo="Typo.subtitle1">태그</MudText>
        </div>
        <MudStack Row Spacing="1" Style="flex-wrap:wrap;">
            @foreach (var tag in _allTags)
            {
                var selected = _selectedTagIds.Contains(tag.Id);
                <MudChip T="string" Size="Size.Small"
                         Style="@(selected ? $"background:{tag.Color};color:white;cursor:pointer;" : $"border-color:{tag.Color};color:{tag.Color};cursor:pointer;opacity:0.6;")"
                         Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => ToggleTag(tag.Id))">@tag.Name</MudChip>
            }
        </MudStack>
    </MudPaper>

    @* 작업자 *@
    <MudPaper Class="pa-4 mb-4 dtl-section" Elevation="0">
        <div class="dtl-section-header">
            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" />
            <MudText Typo="Typo.subtitle1">작업자</MudText>
        </div>
        <MudStack Row Spacing="1" Style="flex-wrap:wrap;">
            @foreach (var worker in _allWorkers)
            {
                var selected = _selectedWorkerIds.Contains(worker.Id);
                <MudChip T="string" Size="Size.Small"
                         Style="@(selected ? $"background:{worker.Color};color:white;cursor:pointer;" : $"border-color:{worker.Color};color:{worker.Color};cursor:pointer;opacity:0.6;")"
                         Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => ToggleWorker(worker.Id))">@worker.Name</MudChip>
            }
        </MudStack>
    </MudPaper>

    @* 체크리스트 (내 작업만 표시) *@
    @if (_todo.AssigneeType == AssigneeType.Mine)
    {
    <MudPaper Class="pa-4 mb-4 dtl-section" Elevation="0">
        <MudStack Row AlignItems="AlignItems.Center" Class="dtl-section-header" Style="margin-bottom:0;">
            <MudIcon Icon="@Icons.Material.Filled.Checklist" Color="Color.Success" />
            <MudText Typo="Typo.subtitle1">체크리스트</MudText>
            @if (_todo.CheckItems.Count > 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2">(@_todo.CheckItems.Count(c => c.IsCompleted)/@_todo.CheckItems.Count)</MudText>
            }
        </MudStack>
        @if (_todo.CheckItems.Count > 0)
        {
            var pct = (double)_todo.CheckItems.Count(c => c.IsCompleted) / _todo.CheckItems.Count * 100;
            <MudProgressLinear Value="pct" Color="@(pct >= 100 ? Color.Success : Color.Primary)" Size="Size.Small" Rounded Class="mb-3" />
        }
        <MudStack Spacing="1">
            @foreach (var item in _todo.CheckItems.OrderBy(c => c.SortOrder))
            {
                <MudStack Row AlignItems="AlignItems.Center">
                    <MudCheckBox T="bool" Value="item.IsCompleted" ValueChanged="_ => ToggleCheck(item)" Dense Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Style="@(item.IsCompleted ? "text-decoration:line-through;opacity:.5;" : "")">@item.Title</MudText>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteCheck(item)" />
                </MudStack>
            }
        </MudStack>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
            <MudTextField @bind-Value="_newCheck" Label="새 항목" Variant="Variant.Outlined" Margin="Margin.Dense" OnKeyDown="@(async e => { if (e.Key == "Enter") await AddCheck(); })" />
            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddCheck" Disabled="@string.IsNullOrWhiteSpace(_newCheck)" />
        </MudStack>
    </MudPaper>
    }

    @* 링크 *@
    <MudPaper Class="pa-4 mb-4 dtl-section" Elevation="0">
        <div class="dtl-section-header">
            <MudIcon Icon="@Icons.Material.Filled.Link" Color="Color.Info" />
            <MudText Typo="Typo.subtitle1">링크</MudText>
        </div>
        @foreach (var link in _todo.Links)
        {
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Style="@(link.LinkTypeColor is not null ? $"color:{link.LinkTypeColor}" : "")" />
                <MudLink Href="@link.Url" Target="_blank" Underline="Underline.Hover">@(string.IsNullOrWhiteSpace(link.Title) ? link.Url : link.Title)</MudLink>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="@(link.LinkTypeColor is not null ? $"border-color:{link.LinkTypeColor};color:{link.LinkTypeColor}" : "")">@(link.LinkTypeName ?? link.LinkType.ToKorean())</MudChip>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteLink(link)" />
            </MudStack>
        }
        <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Class="mt-2">
            <MudTextField @bind-Value="_newLink.Title" Label="제목" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1;" />
            <MudTextField @bind-Value="_newLink.Url" Label="URL" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:2;" />
            <MudSelect T="long?" @bind-Value="_newLink.LinkTypeId" Label="유형" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:120px;" AnchorOrigin="Origin.BottomCenter" Clearable>
                @foreach (var lt in _allLinkTypes) { <MudSelectItem T="long?" Value="lt.Id">@lt.Name</MudSelectItem> }
            </MudSelect>
            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddLink" Disabled="@string.IsNullOrWhiteSpace(_newLink.Url)" />
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public long Id { get; set; }
    private TodoItemDto? _todo;
    private UpdateTodoRequest _form = new();
    private List<ProjectDto> _projects = [];
    private List<TagDto> _allTags = [];
    private List<TeamDto> _teams = [];
    private List<WorkCategoryDto> _availableCategories = [];
    private List<long> _selectedTagIds = [];
    private List<WorkerDto> _allWorkers = [];
    private List<long> _selectedWorkerIds = [];
    private List<LinkTypeDto> _allLinkTypes = [];
    private long? _formTeamId;
    private long? _formWorkCategoryId;
    private System.Threading.Timer? _autoSaveTimer;
    private bool _formIsExternal;
    private string? _formExternalLabel;
    private bool _loading = true, _saving;
    private DateTime? _dueDate, _startDate, _endDate;
    private DateTime? _plannedStartDate, _plannedEndDate;
    private string? _newCheck;
    private CreateLinkRequest _newLink = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            await Task.WhenAll(
                TodoApi.GetByIdAsync(Id).ContinueWith(t => _todo = t.Result),
                ProjectApi.GetAllAsync().ContinueWith(t => _projects = t.Result),
                TagApi.GetAllAsync().ContinueWith(t => _allTags = t.Result),
                TeamApi.GetAllAsync().ContinueWith(t => _teams = t.Result),
                WorkerApi.GetAllAsync().ContinueWith(t => _allWorkers = t.Result),
                LinkTypeApi.GetAllAsync().ContinueWith(t => _allLinkTypes = t.Result));
            if (_todo is not null)
            {
                _form = new() { Title = _todo.Title, Description = _todo.Description, Status = _todo.Status, Priority = _todo.Priority, ProjectId = _todo.ProjectId, TagIds = _todo.Tags.Select(t => t.Id).ToList() };
                _dueDate = _todo.DueDate; _startDate = _todo.StartDate; _endDate = _todo.EndDate;
                _selectedTagIds = _todo.Tags.Select(t => t.Id).ToList();
                _selectedWorkerIds = _todo.Workers.Select(w => w.Id).ToList();
                _plannedStartDate = _todo.PlannedStartDate;
                _plannedEndDate = _todo.PlannedEndDate;
                // 팀/작업분류/담당유형 폼 초기값
                _formTeamId = _todo.TeamId;
                _formWorkCategoryId = _todo.WorkCategoryId;
                _formIsExternal = _todo.IsExternal;
                _formExternalLabel = _todo.ExternalLabel;
                OnTeamChanged();
            }
        }
        catch (Exception ex) { Snackbar.Add($"로드 실패: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    /// <summary>자동 저장 (모든 필드 변경 시 즉시 API 호출)</summary>
    private async Task AutoSaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Title) || _saving) return;
        _saving = true;
        try
        {
            _form.DueDate = _endDate; _form.StartDate = _startDate; _form.EndDate = _endDate; _form.TagIds = _selectedTagIds;
            _form.WorkerIds = _selectedWorkerIds;
            _form.PlannedStartDate = _plannedStartDate;
            _form.PlannedEndDate = _plannedEndDate;
            _form.TeamId = _formTeamId;
            _form.WorkCategoryId = _formWorkCategoryId;
            _form.IsExternal = _formIsExternal;
            _form.ExternalLabel = _formExternalLabel;
            _todo = await TodoApi.UpdateAsync(Id, _form);
        }
        catch (Exception ex) { Snackbar.Add($"자동 저장 실패: {ex.Message}", Severity.Error); }
        finally { _saving = false; StateHasChanged(); }
    }

    /// <summary>수동 저장 버튼</summary>
    private async Task ManualSaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Title)) { Snackbar.Add("제목을 입력하세요.", Severity.Warning); return; }
        _saving = true;
        try
        {
            _form.DueDate = _endDate; _form.StartDate = _startDate; _form.EndDate = _endDate; _form.TagIds = _selectedTagIds;
            _form.WorkerIds = _selectedWorkerIds;
            _form.PlannedStartDate = _plannedStartDate;
            _form.PlannedEndDate = _plannedEndDate;
            _form.TeamId = _formTeamId;
            _form.WorkCategoryId = _formWorkCategoryId;
            _form.IsExternal = _formIsExternal;
            _form.ExternalLabel = _formExternalLabel;
            _todo = await TodoApi.UpdateAsync(Id, _form);
            Snackbar.Add("저장되었습니다.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"저장 실패: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    /// <summary>빠른 상태 전환 (저장 없이 즉시 API 호출)</summary>
    private async Task QuickStatusAsync(TodoStatus newStatus)
    {
        _saving = true;
        try
        {
            await TodoApi.UpdateStatusAsync(Id, newStatus);
            // 서버에서 설정한 ActualStartDate/ActualEndDate 반영을 위해 재조회
            var refreshed = await TodoApi.GetByIdAsync(Id);
            if (refreshed is not null)
            {
                _todo = refreshed;
                _form.Status = refreshed.Status;
            }
            else
            {
                _todo!.Status = newStatus;
                _form.Status = newStatus;
            }
            Snackbar.Add($"상태: {SL(newStatus)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"상태 변경 실패: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    /// <summary>상태 셀렉트 변경 → 즉시 API 호출</summary>
    private async Task OnStatusChanged(TodoStatus newStatus)
    {
        if (_form.Status == newStatus) return;
        _form.Status = newStatus;
        await QuickStatusAsync(newStatus);
    }

    /// <summary>태그 토글 → 즉시 API 호출</summary>
    private async Task ToggleTag(long tagId)
    {
        if (!_selectedTagIds.Remove(tagId)) _selectedTagIds.Add(tagId);
        try
        {
            await TodoApi.UpdateTagsAsync(Id, _selectedTagIds);
        }
        catch (Exception ex) { Snackbar.Add($"태그 변경 실패: {ex.Message}", Severity.Error); }
    }

    /// <summary>작업자 토글 → 즉시 API 호출 + IsMe 기반 AssigneeType 자동 결정</summary>
    private async Task ToggleWorker(long workerId)
    {
        if (!_selectedWorkerIds.Remove(workerId)) _selectedWorkerIds.Add(workerId);
        try
        {
            await TodoApi.UpdateWorkersAsync(Id, _selectedWorkerIds);
            // 작업자 중 IsMe=true가 있으면 내 작업, 없으면 타인 작업 (UI 즉시 반영)
            if (_selectedWorkerIds.Count > 0)
            {
                var hasMe = _allWorkers.Any(w => _selectedWorkerIds.Contains(w.Id) && w.IsMe);
                _todo!.AssigneeType = hasMe ? AssigneeType.Mine : AssigneeType.Others;
            }
        }
        catch (Exception ex) { Snackbar.Add($"작업자 변경 실패: {ex.Message}", Severity.Error); }
    }

    /// <summary>외부 일정 토글 → 즉시 저장</summary>
    private async Task OnExternalChanged(bool val)
    {
        _formIsExternal = val;
        await AutoSaveAsync();
    }

    /// <summary>팀 변경 시 작업 분류 목록 갱신</summary>
    private void OnTeamChanged()
    {
        var team = _teams.FirstOrDefault(t => t.Id == _formTeamId);
        _availableCategories = team?.WorkCategories ?? [];
        if (_availableCategories.All(c => c.Id != _formWorkCategoryId))
            _formWorkCategoryId = _availableCategories.FirstOrDefault()?.Id;
    }

    /// <summary>팀 변경 → 분류 갱신 + 즉시 저장</summary>
    private async Task OnTeamChangedAndSave()
    {
        OnTeamChanged();
        await AutoSaveAsync();
    }

    private async Task ToggleCheck(TodoCheckItemDto item)
    { try { await TodoApi.ToggleCheckItemAsync(Id, item.Id); item.IsCompleted = !item.IsCompleted; } catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); } }

    private async Task AddCheck()
    { if (string.IsNullOrWhiteSpace(_newCheck)) return; try { var c = await TodoApi.CreateCheckItemAsync(Id, _newCheck); if (c is not null) _todo!.CheckItems.Add(c); _newCheck = null; } catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); } }

    private async Task DeleteCheck(TodoCheckItemDto item)
    { try { await TodoApi.DeleteCheckItemAsync(Id, item.Id); _todo!.CheckItems.Remove(item); } catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); } }

    private async Task AddLink()
    { if (string.IsNullOrWhiteSpace(_newLink.Url)) return; try { var l = await TodoApi.CreateLinkAsync(Id, _newLink); if (l is not null) _todo!.Links.Add(l); _newLink = new(); } catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); } }

    private async Task DeleteLink(TodoLinkDto link)
    { try { await TodoApi.DeleteLinkAsync(Id, link.Id); _todo!.Links.Remove(link); } catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); } }

    private async Task DeleteAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync("할일 삭제", $"'{_todo!.Title}'을(를) 삭제하시겠습니까?", yesText: "삭제", cancelText: "취소");
        if (confirmed != true) return;
        _saving = true;
        try
        {
            await TodoApi.DeleteAsync(Id);
            Snackbar.Add("삭제되었습니다.", Severity.Success);
            Navigation.NavigateTo("/todos");
        }
        catch (Exception ex) { Snackbar.Add($"삭제 실패: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DuplicateAsync()
    {
        _saving = true;
        try
        {
            var copy = await TodoApi.DuplicateAsync(Id);
            if (copy is not null)
            {
                Snackbar.Add("복제되었습니다.", Severity.Success);
                Navigation.NavigateTo($"/todos/detail/{copy.Id}");
            }
        }
        catch (Exception ex) { Snackbar.Add($"복제 실패: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    /// <summary>텍스트 필드 변경 시 1초 디바운스 후 자동 저장</summary>
    private void ScheduleAutoSave()
    {
        _autoSaveTimer?.Dispose();
        _autoSaveTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(AutoSaveAsync);
        }, null, 1000, Timeout.Infinite);
    }

    public void Dispose() => _autoSaveTimer?.Dispose();

    static string SL(TodoStatus s) => s.ToKorean();
    static string PL(TodoPriority p) => p.ToKorean();
    static string LinkIcon(LinkType t) => t switch { LinkType.Jira => Icons.Material.Filled.BugReport, LinkType.Confluence => Icons.Material.Filled.MenuBook, LinkType.GitHub or LinkType.GitLab => Icons.Material.Filled.Code, _ => Icons.Material.Filled.Link };
    static Color LinkColor(LinkType t) => t switch { LinkType.Jira => Color.Info, LinkType.Confluence => Color.Warning, LinkType.GitHub or LinkType.GitLab => Color.Dark, _ => Color.Default };
    static Color OthersColor(OthersStatusHelper.ComputedStatus cs) => cs switch
    {
        OthersStatusHelper.ComputedStatus.InProgress => Color.Info,
        OthersStatusHelper.ComputedStatus.Overdue => Color.Error,
        OthersStatusHelper.ComputedStatus.Done => Color.Success,
        OthersStatusHelper.ComputedStatus.EarlyDone => Color.Tertiary,
        OthersStatusHelper.ComputedStatus.LateDone => Color.Warning,
        _ => Color.Default
    };
}
