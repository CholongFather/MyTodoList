@page "/settings"

@inject SettingsApiClient SettingsApi
@inject TagApiClient TagApi
@inject TeamApiClient TeamApi
@inject EnvironmentApiClient EnvApi
@inject HolidayApiClient HolidayApi
@inject AssigneeTypeApiClient AssigneeTypeApi
@inject BusStationApiClient BusStationApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>설정</PageTitle>

<div class="dtl-page-header">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" />
        <MudText Typo="Typo.h5">설정</MudText>
    </MudStack>
</div>

<MudGrid Spacing="3">
    @* 알림 설정 *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 dtl-section" Elevation="0">
            <div class="dtl-section-header">
                <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Warning" />
                <MudText Typo="Typo.subtitle1">알림 설정</MudText>
            </div>
            @if (_notiLoading) { <MudProgressLinear Indeterminate /> }
            else
            {
                <MudStack Spacing="3">
                    <MudSwitch @bind-Value="_noti.IsEnabled" Label="알림 활성화" Color="Color.Primary" />
                    <MudTextField @bind-Value="_noti.NotificationTime" Label="알림 시각 (HH:mm)" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="_noti.DashboardRefreshIntervalSeconds" Label="대시보드 새로고침 간격 (초)" Variant="Variant.Outlined" Min="30" Max="3600" />
                    <MudNumericField @bind-Value="_noti.DueSoonDays" Label="마감 임박 알림 (N일 전)" Variant="Variant.Outlined" Min="1" Max="14" />
                    <MudTextField @bind-Value="_noti.GbisApiKey" Label="GBIS API 인증키 (공공데이터포털)" Variant="Variant.Outlined"
                                  Placeholder="공공데이터포털 발급 일반인증키" HelperText="경기도 버스도착정보 API용" />
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Teams 워크플로 URL</MudText>
                    <MudTextField @bind-Value="_noti.ScheduleWebhookUrl" Label="일정 알리미" Variant="Variant.Outlined"
                                  Placeholder="Power Automate Workflow URL" />
                    <MudTextField @bind-Value="_noti.BusWebhookUrl" Label="버스 알리미" Variant="Variant.Outlined"
                                  Placeholder="Power Automate Workflow URL" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveNotiAsync" Disabled="_notiSaving" StartIcon="@Icons.Material.Filled.Save">저장</MudButton>
                </MudStack>
            }
        </MudPaper>
    </MudItem>

    @* 태그 관리 *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 dtl-section" Elevation="0">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Label" Color="Color.Secondary" />
                    <MudText Typo="Typo.subtitle1">태그 관리</MudText>
                </MudStack>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="OpenAddTag" StartIcon="@Icons.Material.Filled.Add">추가</MudButton>
            </MudStack>

            @if (_tagLoading) { <MudProgressLinear Indeterminate /> }
            else
            {
                <MudSimpleTable Dense Hover Striped Style="border-radius:8px;">
                    <thead><tr><th>색상</th><th>이름</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var tag in _tags)
                        {
                            <tr>
                                <td><div style="width:24px;height:24px;border-radius:50%;background:@tag.Color;"></div></td>
                                <td>@tag.Name</td>
                                <td style="text-align:right;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteTag(tag)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>

                @if (_addingTag)
                {
                    <MudStack Spacing="2" Class="mt-3">
                        <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                            <MudTextField @bind-Value="_newTagName" Label="태그 이름" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1;" />
                            <div style="width:28px;height:28px;border-radius:50%;background:@_newTagColorHex;border:2px solid #ddd;flex-shrink:0;"></div>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="CreateTag" Disabled="@string.IsNullOrWhiteSpace(_newTagName)">추가</MudButton>
                            <MudButton Size="Size.Small" OnClick="() => _addingTag = false">취소</MudButton>
                        </MudStack>
                        <div style="display:flex;flex-wrap:wrap;gap:6px;">
                            @foreach (var c in _tagColorPalette)
                            {
                                <div @onclick="() => _newTagColorHex = c"
                                     style="width:26px;height:26px;border-radius:50%;background:@c;cursor:pointer;border:@(c == _newTagColorHex ? "3px solid #333" : "2px solid transparent");transition:border .15s;" />
                            }
                        </div>
                    </MudStack>
                }
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@* === 팀/작업분류 관리 === *@
<MudText Typo="Typo.h6" Class="mb-3 mt-6">팀 / 작업분류 관리</MudText>
<MudPaper Class="dtl-section pa-4" Elevation="0">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <MudTextField T="string" @bind-Value="_newTeamName" Label="새 팀 이름" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;" />
        <div style="width:28px;height:28px;border-radius:50%;background:@_newTeamColorHex;border:2px solid #ddd;flex-shrink:0;"></div>
        <MudTextField T="string" @bind-Value="_newTeamColorHex" Label="색상" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:100px;" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddTeamAsync" Disabled="@string.IsNullOrWhiteSpace(_newTeamName)">팀 추가</MudButton>
    </MudStack>

    @foreach (var team in _teams)
    {
        <MudPaper Class="pa-3 mb-2" Elevation="0" Style="@($"border-left:4px solid {team.Color}; background:var(--mud-palette-surface);")">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@team.Name</MudText>
                @if (team.IsMine)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">내 팀</MudChip>
                }
                <MudSpacer />
                <MudSwitch T="bool" Value="team.IsMine" ValueChanged="@(async (bool v) => await ToggleIsMyTeamAsync(team, v))"
                           Color="Color.Primary" Size="Size.Small" Label="내 팀" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteTeamAsync(team.Id))" />
            </MudStack>

            <MudStack Row Spacing="1" Class="mb-1" Style="flex-wrap:wrap;">
                @foreach (var cat in team.WorkCategories)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" OnClose="@(() => DeleteCategoryAsync(cat.Id))">@cat.Name</MudChip>
                }
            </MudStack>

            <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                <MudTextField T="string" @bind-Value="_newCategoryNames[team.Id]" Label="작업분류 추가" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:180px;" />
                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary" OnClick="@(() => AddCategoryAsync(team.Id))" />
            </MudStack>
        </MudPaper>
    }
</MudPaper>

@* === 환경 관리 === *@
<MudText Typo="Typo.h6" Class="mb-3 mt-6">배포 환경 관리</MudText>
<MudPaper Class="dtl-section pa-4" Elevation="0">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <MudTextField T="string" @bind-Value="_newEnvName" Label="환경 이름" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;" Placeholder="예: Dev, QA, Live" />
        <div style="width:28px;height:28px;border-radius:50%;background:@_newEnvColorHex;border:2px solid #ddd;flex-shrink:0;"></div>
        <MudTextField T="string" @bind-Value="_newEnvColorHex" Label="색상" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:100px;" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddEnvAsync" Disabled="@string.IsNullOrWhiteSpace(_newEnvName)">추가</MudButton>
    </MudStack>

    <MudStack Row Spacing="1" Style="flex-wrap:wrap;">
        @foreach (var env in _envs)
        {
            <MudChip T="string" Size="Size.Small" Style="@($"background:{env.Color}; color:white;")" OnClose="@(() => DeleteEnvAsync(env.Id))">@env.Name</MudChip>
        }
    </MudStack>
</MudPaper>

@* === 담당 유형 관리 === *@
<MudText Typo="Typo.h6" Class="mb-3 mt-6">담당 유형 관리</MudText>
<MudPaper Class="dtl-section pa-4" Elevation="0">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <MudTextField T="string" @bind-Value="_newAtName" Label="유형 이름" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;" Placeholder="예: 내 작업, 협업" />
        <div style="width:28px;height:28px;border-radius:50%;background:@_newAtColorHex;border:2px solid #ddd;flex-shrink:0;"></div>
        <MudTextField T="string" @bind-Value="_newAtColorHex" Label="색상" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:100px;" />
        <MudCheckBox T="bool" @bind-Value="_newAtIsMine" Label="내 작업 동작" Color="Color.Primary" Dense />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddAssigneeTypeAsync" Disabled="@string.IsNullOrWhiteSpace(_newAtName)">추가</MudButton>
    </MudStack>

    <MudSimpleTable Dense Hover Striped Elevation="0" Style="border-radius:8px;">
        <thead><tr><th style="width:60px;">순서</th><th style="width:40px;">색상</th><th>이름</th><th style="width:80px;">동작</th><th style="width:40px;"></th></tr></thead>
        <tbody>
            @for (var i = 0; i < _assigneeTypes.Count; i++)
            {
                var at = _assigneeTypes[i];
                var idx = i;
                <tr>
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Disabled="@(idx == 0)" OnClick="@(() => MoveAssigneeTypeAsync(idx, -1))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Disabled="@(idx == _assigneeTypes.Count - 1)" OnClick="@(() => MoveAssigneeTypeAsync(idx, 1))" />
                    </td>
                    <td><div style="width:24px;height:24px;border-radius:50%;background:@at.Color;"></div></td>
                    <td>@at.Name</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@(at.IsMine ? Color.Primary : Color.Warning)" Variant="Variant.Filled">@(at.IsMine ? "내 작업" : "타인")</MudChip></td>
                    <td><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAssigneeTypeAsync(at.Id))" /></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
</MudPaper>

@* === 버스 정류장 관리 === *@
<MudText Typo="Typo.h6" Class="mb-3 mt-6">버스 정류장 관리</MudText>
<MudPaper Class="dtl-section pa-4" Elevation="0">
    @if (_stationLoading) { <MudProgressLinear Indeterminate /> }
    else
    {
        <MudSimpleTable Dense Hover Striped Elevation="0" Style="border-radius:8px;">
            <thead>
                <tr>
                    <th>이름</th>
                    <th>노선</th>
                    <th>정류장</th>
                    <th>방향</th>
                    <th style="width:180px;">GBIS 정보</th>
                    <th style="width:40px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var st in _stations)
                {
                    <tr>
                        <td><MudText Typo="Typo.body2" Style="font-weight:600;">@st.Name</MudText></td>
                        <td>@st.BusRouteNumber</td>
                        <td>@st.BusStopName</td>
                        <td>
                            @if (st.Direction != BusDirection.Unspecified)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(st.Direction == BusDirection.Upbound ? Color.Info : Color.Warning)">@st.Direction.ToKorean()</MudChip>
                            }
                        </td>
                        <td><MudText Typo="Typo.caption" Class="mud-text-secondary">@st.GbisStationId / @st.GbisRouteId / @st.GbisStaOrder</MudText></td>
                        <td><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteStationAsync(st.Id))" /></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Class="mt-3" Style="flex-wrap:wrap;">
            <MudTextField T="string" @bind-Value="_newStName" Label="이름" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:140px;" Placeholder="예: 청현마을-1112" />
            <MudTextField T="string" @bind-Value="_newStRoute" Label="노선" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:100px;" Placeholder="1112" />
            <MudTextField T="string" @bind-Value="_newStStop" Label="정류장" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:160px;" Placeholder="청현마을·수원신갈IC" />
            <MudSelect T="int" @bind-Value="_newStDirection" Label="방향" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:100px;">
                <MudSelectItem T="int" Value="0">미지정</MudSelectItem>
                <MudSelectItem T="int" Value="1">상행</MudSelectItem>
                <MudSelectItem T="int" Value="2">하행</MudSelectItem>
            </MudSelect>
            <MudTextField T="string" @bind-Value="_newStGbisStation" Label="정류소ID" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:120px;" />
            <MudTextField T="string" @bind-Value="_newStGbisRoute" Label="노선ID" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:120px;" />
            <MudNumericField T="int?" @bind-Value="_newStGbisOrder" Label="순번" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:80px;" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddStationAsync"
                       Disabled="@(string.IsNullOrWhiteSpace(_newStName) || string.IsNullOrWhiteSpace(_newStRoute))">추가</MudButton>
        </MudStack>
    }
</MudPaper>

@* === 공휴일/연차 관리 === *@
<MudText Typo="Typo.h6" Class="mb-3 mt-6">공휴일 / 연차 관리</MudText>
<MudPaper Class="dtl-section pa-4" Elevation="0">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <MudSelect T="int" @bind-Value="_holidayYear" Label="연도" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:120px;" AnchorOrigin="Origin.BottomCenter">
            @foreach (var y in _yearOptions)
            { <MudSelectItem T="int" Value="y">@y</MudSelectItem> }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="LoadHolidaysAsync" StartIcon="@Icons.Material.Filled.Refresh">조회</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" OnClick="SeedKoreanHolidaysAsync" StartIcon="@Icons.Material.Filled.AutoAwesome">한국 공휴일 불러오기</MudButton>
    </MudStack>

    @if (_holidays.Count > 0)
    {
        <MudSimpleTable Dense Hover Striped Elevation="0" Style="border-radius:8px;">
            <thead><tr><th style="width:70px;">유형</th><th style="width:120px;">날짜</th><th>이름</th><th style="width:60px;">반복</th><th style="width:40px;"></th></tr></thead>
            <tbody>
                @foreach (var h in _holidays)
                {
                    <tr>
                        <td>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                     Color="@(h.HolidayType == HolidayType.PersonalLeave ? Color.Secondary : Color.Info)">
                                @(h.HolidayType == HolidayType.PersonalLeave ? "연차" : "공휴일")
                            </MudChip>
                        </td>
                        <td><MudText Typo="Typo.body2">@h.Date.ToString("yyyy-MM-dd")</MudText></td>
                        <td><MudText Typo="Typo.body2">@h.Name</MudText></td>
                        <td>@(h.IsRecurring ? "매년" : "")</td>
                        <td><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteHolidayAsync(h.Id))" /></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense>등록된 공휴일이 없습니다. '한국 공휴일 불러오기'를 눌러주세요.</MudAlert>
    }

    <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Class="mt-3" Style="flex-wrap:wrap;">
        <MudSelect T="HolidayType" @bind-Value="_newHolidayType" Label="유형" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:120px;">
            <MudSelectItem T="HolidayType" Value="HolidayType.PublicHoliday">공휴일</MudSelectItem>
            <MudSelectItem T="HolidayType" Value="HolidayType.PersonalLeave">연차</MudSelectItem>
        </MudSelect>
        <MudDatePicker @bind-Date="_newHolidayDate" Label="날짜" Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="yyyy-MM-dd" Style="max-width:160px;"
                       AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.BottomLeft" />
        <MudTextField T="string" @bind-Value="_newHolidayName" Label="이름" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;" />
        <MudCheckBox T="bool" @bind-Value="_newHolidayRecurring" Label="매년 반복" Dense />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddHolidayAsync"
                   Disabled="@(_newHolidayDate is null || string.IsNullOrWhiteSpace(_newHolidayName))">추가</MudButton>
    </MudStack>
</MudPaper>

@code {
    private NotificationSettingDto _noti = new();
    private List<TagDto> _tags = [];
    private bool _notiLoading = true, _notiSaving, _tagLoading = true, _addingTag;
    private string? _newTagName;
    private string _newTagColorHex = "#9E9E9E";

    // 태그 색상 팔레트 (20색)
    private static readonly string[] _tagColorPalette =
    [
        "#F44336", "#E91E63", "#9C27B0", "#673AB7", "#3F51B5",
        "#2196F3", "#03A9F4", "#00BCD4", "#009688", "#4CAF50",
        "#8BC34A", "#CDDC39", "#FFC107", "#FF9800", "#FF5722",
        "#795548", "#607D8B", "#9E9E9E", "#000000", "#37474F"
    ];

    // 팀/작업분류 관리 필드
    private List<TeamDto> _teams = [];
    private string _newTeamName = "";
    private string _newTeamColorHex = "";
    private Dictionary<long, string> _newCategoryNames = new();

    // 팀 색상 랜덤 팔레트
    private static readonly string[] _teamColorPalette =
    [
        "#E91E63", "#9C27B0", "#673AB7", "#3F51B5", "#2196F3",
        "#00BCD4", "#009688", "#4CAF50", "#8BC34A", "#FF9800",
        "#FF5722", "#795548", "#607D8B", "#F44336", "#1976D2"
    ];
    private string RandomTeamColor() => _teamColorPalette[Random.Shared.Next(_teamColorPalette.Length)];

    // 환경 관리 필드
    private List<EnvironmentDto> _envs = [];
    private string _newEnvName = "";
    private string _newEnvColorHex = "";

    // 담당 유형 관리 필드
    private List<AssigneeTypeDto> _assigneeTypes = [];
    private string _newAtName = "";
    private string _newAtColorHex = "";
    private bool _newAtIsMine;

    // 버스 정류장 관리 필드
    private List<BusStationDto> _stations = [];
    private bool _stationLoading = true;
    private string _newStName = "", _newStRoute = "", _newStStop = "";
    private int _newStDirection;
    private string? _newStGbisStation, _newStGbisRoute;
    private int? _newStGbisOrder;

    // 공휴일 관리 필드
    private List<HolidayDto> _holidays = [];
    private int _holidayYear = DateTime.Now.Year;
    private static readonly int[] _yearOptions = Enumerable.Range(DateTime.Now.Year - 1, 4).ToArray();
    private DateTime? _newHolidayDate;
    private string _newHolidayName = "";
    private bool _newHolidayRecurring;
    private HolidayType _newHolidayType;

    protected override async Task OnInitializedAsync()
    {
        _newTeamColorHex = RandomTeamColor();
        _newEnvColorHex = RandomTeamColor();
        _newAtColorHex = RandomTeamColor();
        try { _noti = await SettingsApi.GetNotificationsAsync(); } catch { } finally { _notiLoading = false; }
        try { _tags = await TagApi.GetAllAsync(); } catch { } finally { _tagLoading = false; }
        await LoadTeamsAsync();
        await LoadEnvsAsync();
        await LoadStationsAsync();
        await LoadHolidaysAsync();
        await LoadAssigneeTypesAsync();
    }

    private async Task SaveNotiAsync()
    {
        _notiSaving = true;
        try { await SettingsApi.UpdateNotificationsAsync(_noti); Snackbar.Add("저장되었습니다.", Severity.Success); }
        catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); }
        finally { _notiSaving = false; }
    }

    private void OpenAddTag() { _addingTag = true; _newTagName = null; _newTagColorHex = "#9E9E9E"; }

    private async Task CreateTag()
    {
        if (string.IsNullOrWhiteSpace(_newTagName)) return;
        try
        {
            var tag = await TagApi.CreateAsync(new CreateTagRequest { Name = _newTagName, Color = _newTagColorHex });
            if (tag is not null) _tags.Add(tag);
            _addingTag = false;
            Snackbar.Add("태그가 추가되었습니다.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); }
    }

