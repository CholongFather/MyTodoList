@page "/settings"

@inject NavigationManager Navigation

<PageTitle>설정</PageTitle>

<div class="dtl-page-header">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" />
        <MudText Typo="Typo.h5">설정</MudText>
    </MudStack>
</div>

<MudGrid Spacing="3">
    @foreach (var item in _menuItems)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-4 dtl-section" Elevation="0" Style="cursor:pointer;" @onclick="@(() => Navigation.NavigateTo(item.Href))">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@item.Icon" Color="@item.Color" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@item.Title</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.Description</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    private record MenuItem(string Title, string Description, string Href, string Icon, Color Color);

    private static readonly MenuItem[] _menuItems =
    [
        new("알림 설정", "알림 시각, Teams 웹훅, GBIS API 키", "/settings/notifications", Icons.Material.Filled.Notifications, Color.Warning),
        new("태그 관리", "할일에 사용할 태그 추가/수정/삭제", "/settings/tags", Icons.Material.Filled.Label, Color.Secondary),
        new("팀 / 작업분류", "팀 관리 및 작업분류 설정", "/settings/teams", Icons.Material.Filled.Groups, Color.Primary),
        new("작업자 관리", "작업자 등록 및 '나' 설정", "/settings/workers", Icons.Material.Filled.People, Color.Info),
        new("배포 환경", "Dev, QA, Live 등 환경 관리", "/settings/environments", Icons.Material.Filled.Cloud, Color.Info),
        new("노트 유형", "케이스 노트 유형 관리", "/settings/note-types", Icons.Material.Filled.StickyNote2, Color.Warning),
        new("링크 유형", "Jira, Confluence 등 링크 유형 관리", "/settings/link-types", Icons.Material.Filled.Link, Color.Success),
        new("버스 정류장", "GBIS 버스 도착 알림 정류장 설정", "/settings/bus-stations", Icons.Material.Filled.DirectionsBus, Color.Success),
        new("공휴일 / 연차", "공휴일 및 연차 관리", "/settings/holidays", Icons.Material.Filled.CalendarMonth, Color.Error),
    ];
}
