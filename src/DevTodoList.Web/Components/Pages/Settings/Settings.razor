    private async Task MoveAssigneeTypeAsync(int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= _assigneeTypes.Count) return;
        (_assigneeTypes[index], _assigneeTypes[newIndex]) = (_assigneeTypes[newIndex], _assigneeTypes[index]);
        try
        {
            await AssigneeTypeApi.ReorderAsync(_assigneeTypes.Select(x => x.Id).ToList());
        }
        catch (Exception ex) { Snackbar.Add($"순서 변경 실패: {ex.Message}", Severity.Error); await LoadAssigneeTypesAsync(); }
    }

    private async Task DeleteAssigneeTypeAsync(long id)
    {
        var at = _assigneeTypes.FirstOrDefault(x => x.Id == id);
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "담당 유형 삭제",
            $"'{at?.Name}'을(를) 삭제하시겠습니까? 이 유형을 사용 중인 할일의 담당 유형이 초기화됩니다.",
            yesText: "삭제", cancelText: "취소");
        if (confirmed != true) return;
        try
        {
            await AssigneeTypeApi.DeleteAsync(id);
            await LoadAssigneeTypesAsync();
            Snackbar.Add("삭제되었습니다.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"실패: {ex.Message}", Severity.Error); }
    }
